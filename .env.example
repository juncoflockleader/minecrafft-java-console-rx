# Copy to .env and fill in. The web server reads these on startup.

# Where the web UI listens.
HOST=127.0.0.1
PORT=8765

# RCON connection to the Minecraft server (required).
RCON_HOST=127.0.0.1
RCON_PORT=25575
RCON_PASSWORD=change-me

# Server List Ping target (for the status panel). Defaults to RCON_HOST:25565.
MC_HOST=127.0.0.1
MC_PORT=25565

# Path to the server console/latest log for live streaming (optional).
# Vanilla/Paper: <server>/logs/latest.log  (or the launchd console.log)
MC_LOG_PATH=/Users/localadmin/minecraft/logs/latest.log

# Optional HTTP Basic Auth for the web UI. Leave both empty to disable.
WEBUI_USER=
WEBUI_PASSWORD=

# Server install directory — enables plugin/mods/settings management panels.
# Plugins -> <dir>/plugins, mods -> <dir>/mods, settings -> <dir>/server.properties
MC_SERVER_DIR=/Users/localadmin/minecraft
# Override the plugins/mods dirs individually if they live elsewhere (optional).
# MC_PLUGINS_DIR=
# MC_MODS_DIR=          # set this to enable the Mods panel on a Fabric/Forge server

# Command the "Restart server" button runs. Leave empty to disable that button.
MC_RESTART_COMMAND=sudo launchctl kickstart -k system/com.junco.minecraft
